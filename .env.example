# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/davandee_hrms

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ISSUER=davandee-auth-service
JWT_AUDIENCE=davandee-platform
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# Rate Limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOCKOUT_DURATION_MINUTES=30

# bcrypt
BCRYPT_ROUNDS=12
